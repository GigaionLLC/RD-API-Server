APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Initial administrator created by `php artisan db:seed` when no matching user exists.
# Local/testing seeds use a development-only fallback when ADMIN_PASS is empty. Production has
# no fallback and refuses missing, short, known, placeholder, or username-derived passwords.
ADMIN_USER=admin
ADMIN_PASS=

# Comma-separated IP addresses/CIDR ranges of reverse proxies that sanitize forwarded headers.
# Leave empty when clients connect directly; never use a wildcard.
TRUSTED_PROXIES=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# Keep cross-algorithm password checks available until every legacy bcrypt hash has migrated.
HASH_VERIFY=false
ARGON_MEMORY=65536
ARGON_THREADS=1
ARGON_TIME=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — MySQL/MariaDB by default (scales with your device fleet; SQLite is single-writer).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rustdesk_api
DB_USERNAME=rustdesk
DB_PASSWORD=rustdesk
# Prefer SQLite for a small setup (< ~50 devices) or a quick local run? Comment the six lines
# above and uncomment the next line (data lives in database/database.sqlite):
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Device enrollment fails closed by default. Set REQUIRE_DEPLOYMENT=false and AUTO_REGISTER=true
# together only when legacy unauthenticated enrollment is intentionally required.
RUSTDESK_REQUIRE_DEPLOYMENT=true
RUSTDESK_AUTO_REGISTER=false
RUSTDESK_AUTO_REGISTER_PER_IP_PER_MINUTE=30
RUSTDESK_AUTO_REGISTER_GLOBAL_PER_MINUTE=100
RUSTDESK_AUTO_REGISTER_MAX_DEVICES=5000

# Comma-separated destination ports permitted for outbound HTTP(S) webhooks.
RUSTDESK_WEBHOOK_ALLOWED_PORTS=80,443

# Comma-separated public HTTPS ports permitted for generic OIDC provider endpoints.
RUSTDESK_OIDC_ALLOWED_PORTS=443

# Audit-ingestion burst limits (one-minute windows). Invalid requests are limited per source
# IP; valid requests have a generous aggregate IP ceiling plus a per-device/event ceiling.
RUSTDESK_AUDIT_INVALID_PER_IP=300
RUSTDESK_AUDIT_VALID_PER_IP=12000
RUSTDESK_AUDIT_CONN_PER_DEVICE=240
RUSTDESK_AUDIT_FILE_PER_DEVICE=1200
RUSTDESK_AUDIT_ALARM_PER_DEVICE=60

# Session-recording uploads are disabled until both this switch and one authorization path
# are configured. Stock clients send no token, so list their literal source IPs/CIDRs. A
# trusted proxy/custom client may instead supply the 32+ character token in Authorization:
# Bearer or X-Recording-Token. Never expose an all-address CIDR on an Internet-facing API.
RUSTDESK_RECORDING_UPLOAD_ENABLED=false
RUSTDESK_RECORDING_UPLOAD_ALLOWED_IPS=
RUSTDESK_RECORDING_UPLOAD_TOKEN=
RUSTDESK_RECORDING_UPLOAD_RATE_LIMIT=600
RUSTDESK_RECORDING_UPLOAD_MAX_CHUNK_BYTES=8388608
RUSTDESK_RECORDING_UPLOAD_MAX_FILE_BYTES=2147483648
RUSTDESK_RECORDING_UPLOAD_MAX_TOTAL_BYTES=10737418240
RUSTDESK_RECORDING_UPLOAD_MAX_TOTAL_FILES=5000
RUSTDESK_RECORDING_UPLOAD_MAX_ACTIVE_PER_SOURCE=4

# LDAP / Active Directory authentication (disabled by default; see config/ldap.php).
# When enabled, client and admin login try LDAP first and fall back to local passwords.
LDAP_ENABLED=false
LDAP_HOST=ldap.example.com
LDAP_PORT=389
LDAP_BASE_DN="dc=example,dc=com"
# Stable directory namespace; blank derives one from host, port, and base DN.
LDAP_PROVIDER_ID=
# Immutable identity attribute: entryUUID for OpenLDAP, objectGUID for Active Directory.
LDAP_SUBJECT_ATTR=entryUUID
LDAP_BIND_DN="cn=admin,dc=example,dc=com"
LDAP_BIND_PASSWORD=
# %s is replaced with the login username (use (sAMAccountName=%s) for Active Directory).
LDAP_USER_FILTER="(uid=%s)"
LDAP_USERNAME_ATTR=uid
LDAP_EMAIL_ATTR=mail
LDAP_DISPLAYNAME_ATTR=cn
# Bare hosts use LDAP_PORT. URI endpoints use an embedded port or their 389/636 scheme default.
# Bare hosts and ldap:// use StartTLS; ldaps:// uses implicit TLS without a second upgrade.
LDAP_USE_STARTTLS=true
LDAP_TLS_VERIFY=true
# DANGER: permits plaintext LDAP or unverified TLS for isolated legacy environments only.
LDAP_ALLOW_INSECURE=false
# Optional group DNs. admin-group grants admin rights; allow-group, when set, denies non-members.
LDAP_ADMIN_GROUP=
LDAP_ALLOW_GROUP=
# Update local email/display_name/is_admin from LDAP on every login when true.
LDAP_SYNC=false
