meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/login
  body: json
  auth: none
}

body:json {
  {
    "username": "admin",
    "password": "admin",
    "id": "bruno",
    "uuid": "bruno-uuid"
  }
}

script:post-response {
  if (res.body && res.body.access_token) {
    bru.setEnvVar("account_token", res.body.access_token);
  }
}
